{
    "buildCommand": "cd backend && python manage.py collectstatic --noinput",
    "functions": {
        "backend/python_web_sql/wsgi.py": {
            "runtime": "python3.12"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "backend/python_web_sql/wsgi.py"
        }
    ] 
}